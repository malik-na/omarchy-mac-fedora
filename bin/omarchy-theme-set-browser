#!/bin/bash

CHROMIUM_THEME=~/.config/omarchy/current/theme/chromium.theme

# Use a default, neutral grey if theme doesn't have a color
THEME_RGB_COLOR="28,32,39"
THEME_HEX_COLOR="#1c2027"

if [[ -f $CHROMIUM_THEME ]]; then
  THEME_RGB_COLOR=$(<$CHROMIUM_THEME)
  THEME_HEX_COLOR=$(printf '#%02x%02x%02x' ${THEME_RGB_COLOR//,/ })
fi

# Try to handle flatpak policy paths dynamically if app exists
FLATPAK_APPS=(
  "com.google.Chrome:google-chrome"
  "com.brave.Browser:brave"
  "org.chromium.Chromium:chromium"
)

for app_info in "${FLATPAK_APPS[@]}"; do
  app_id="${app_info%%:*}"
  app_dir="${app_info#*:}"
  
  if [[ -d "$HOME/.var/app/$app_id" ]]; then
    # Ensure policy directory exists
    mkdir -p "$HOME/.var/app/$app_id/config/$app_dir/policies/managed"
  fi
done

# Define all possible policy directories we might want to update
POLICY_DIRS=(
  "/etc/chromium/policies/managed"
  "/etc/chromium-browser/policies/managed"
  "/etc/brave/policies/managed"
  "/etc/opt/chrome/policies/managed"
  "/etc/opt/edge/policies/managed"
  "$HOME/.var/app/com.google.Chrome/config/google-chrome/policies/managed"
  "$HOME/.var/app/com.brave.Browser/config/brave/policies/managed"
  "$HOME/.var/app/org.chromium.Chromium/config/chromium/policies/managed"
)

# Loop and write color.json where we have write access
for pd in "${POLICY_DIRS[@]}"; do
  if [[ -w "$pd" ]]; then
    echo "{\"BrowserThemeColor\": \"$THEME_HEX_COLOR\"}" > "$pd/color.json"
  fi
done

# Refresh running browsers and set mode
if omarchy-cmd-present chromium; then
  chromium --no-startup-window --set-theme-color="$THEME_RGB_COLOR"
  if [[ -f ~/.config/omarchy/current/theme/light.mode ]]; then
    chromium --no-startup-window --set-color-scheme="light"
  else
    chromium --no-startup-window --set-color-scheme="dark"
  fi
fi

# Fedora: mainline chromium package provides chromium-browser, not chromium
if omarchy-cmd-present chromium-browser; then
  chromium-browser --no-startup-window --set-theme-color="$THEME_RGB_COLOR"
  if [[ -f ~/.config/omarchy/current/theme/light.mode ]]; then
    chromium-browser --no-startup-window --set-color-scheme="light"
  else
    chromium-browser --no-startup-window --set-color-scheme="dark"
  fi
fi

if omarchy-cmd-present brave; then
  brave --refresh-platform-policy --no-startup-window
  brave --no-startup-window --set-theme-color="$THEME_RGB_COLOR"
fi

# Fedora: brave package provides brave-browser, not brave
if omarchy-cmd-present brave-browser; then
  brave-browser --refresh-platform-policy --no-startup-window
  brave-browser --no-startup-window --set-theme-color="$THEME_RGB_COLOR"
fi

if omarchy-cmd-present google-chrome; then
  google-chrome --no-startup-window --set-theme-color="$THEME_RGB_COLOR"
fi

if omarchy-cmd-present google-chrome-stable; then
  google-chrome-stable --no-startup-window --set-theme-color="$THEME_RGB_COLOR"
fi

if omarchy-cmd-present helium-browser; then
  helium-browser --no-startup-window --set-theme-color="$THEME_RGB_COLOR"
fi
