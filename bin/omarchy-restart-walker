#!/bin/bash

restart_services() {
	systemctl --user daemon-reload

	unit_exists() {
		local unit="$1"
		systemctl --user list-unit-files --no-legend --type=service 2>/dev/null | awk '{print $1}' | grep -Fxq "$unit" && return 0
		systemctl --user list-units --all --no-legend --type=service 2>/dev/null | awk '{print $1}' | grep -Fxq "$unit" && return 0
		return 1
	}

	restart_if_present() {
		local unit="$1"
		if unit_exists "$unit"; then
			systemctl --user restart "$unit" || echo -e "\e[33mFailed to restart $unit\e[0m"
			return 0
		fi
		return 1
	}

	restart_if_present elephant.service || true

	if ! restart_if_present app-walker@autostart.service; then
		echo -e "\e[33mWalker unit app-walker@autostart.service not found; skip restart\e[0m"
	fi
}

if ((EUID == 0)); then
	script_owner=$(stat -c '%U' "$0")
	user_uid=$(id -u "$script_owner")
	systemd-run --uid="$script_owner" --setenv=XDG_RUNTIME_DIR="/run/user/$user_uid" \
		bash -c "$(declare -f restart_services); restart_services"
else
	restart_services
fi
