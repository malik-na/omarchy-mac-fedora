#!/bin/bash

set -euo pipefail

launch_waybar_once() {
	if command -v uwsm-app >/dev/null 2>&1; then
		setsid uwsm-app -- waybar >/dev/null 2>&1 &
	else
		setsid waybar >/dev/null 2>&1 &
	fi
}

# Stop all current instances first, then wait briefly until they are gone.
pkill -x waybar 2>/dev/null || true
for _ in {1..30}; do
	if ! pgrep -x waybar >/dev/null 2>&1; then
		break
	fi
	sleep 0.1
done

launch_waybar_once

# Give the new instance time to show up in process table on slower first-session starts.
for _ in {1..50}; do
	if pgrep -x waybar >/dev/null 2>&1; then
		exit 0
	fi
	sleep 0.1
done

exit 0
