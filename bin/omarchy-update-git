#!/bin/bash

set -e

echo -e "\e[32mUpdate Omarchy\e[0m"

git -C $OMARCHY_PATH fetch --tags
git -C $OMARCHY_PATH pull --autostash
git -C $OMARCHY_PATH diff --check || git -C $OMARCHY_PATH reset --merge

# Update version file from highest merged release tag.
# Using describe can pick an older local tag after merge-heavy histories.
latest_tag=$(git -C "$OMARCHY_PATH" tag --merged HEAD --list 'v*' | sed 's/^v//' | sort -V | tail -1)
current_version=$(cat "$OMARCHY_PATH/version" 2>/dev/null || true)
if [ -n "$latest_tag" ]; then
  # Keep a newer branch version if release tags are behind.
  if [ -z "$current_version" ] || [ "$(printf '%s\n%s\n' "$current_version" "$latest_tag" | sort -V | tail -1)" = "$latest_tag" ]; then
    echo "$latest_tag" > "$OMARCHY_PATH/version"
  fi
fi
