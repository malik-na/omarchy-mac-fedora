if command -v mise &> /dev/null; then
  eval "$(mise activate bash)"
fi

if command -v starship &> /dev/null; then
  eval "$(starship init bash)"
fi

if command -v zoxide &> /dev/null; then
  eval "$(zoxide init bash)"
fi

if command -v try &> /dev/null; then
  eval "$(SHELL=/bin/bash command try init ~/Work/tries)"
fi

if command -v fzf &> /dev/null; then
  # Fedora stores these under shell/, upstream distros at the parent dir
  for _fzf_completion in /usr/share/fzf/shell/completion.bash /usr/share/fzf/completion.bash; do
    [[ -f $_fzf_completion ]] && source "$_fzf_completion" && break
  done
  for _fzf_keybindings in /usr/share/fzf/shell/key-bindings.bash /usr/share/fzf/key-bindings.bash; do
    [[ -f $_fzf_keybindings ]] && source "$_fzf_keybindings" && break
  done
  unset _fzf_completion _fzf_keybindings
fi
